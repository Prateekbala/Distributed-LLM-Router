{
  "title": "LLM Inference Dashboard",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests/sec",
      "targets": [
        {
          "expr": "sum(rate(requests_total[1m]))"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Active Requests",
      "targets": [{ "expr": "active_requests" }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "p95 Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(request_latency_seconds_bucket[5m])) by (le))"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "Queue Depth",
      "targets": [{ "expr": "queue_depth" }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "Requests per node (rate)",
      "targets": [
        { "expr": "sum by (node) (rate(requests_per_node_total[1m]))" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "type": "timeseries",
      "title": "Active requests per node",
      "targets": [{ "expr": "node_active_requests" }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    },
    {
      "type": "timeseries",
      "title": "Node failures (rate)",
      "targets": [
        { "expr": "sum by (node) (rate(node_failures_total[1m]))" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 }
    }
  ]
}

